# VoxFlow — Environment Configuration Example
# Copy this file to `.env` and fill with your actual values.

# Core provider selection
LLM_PROVIDER=gemini

# LLM keys
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=

# Voice (optional Vapi)
VAPI_PUBLIC_KEY=
VAPI_ASSISTANT_ID=

# Qdrant / retrieval
QDRANT_URL=https://your-qdrant-instance-url
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION=voxflow-kb
PYTHON_QDRANT_URL=http://127.0.0.1:8001

# Debug mode
DEBUG_MODE=false

# SMTP for real email sending (optional)
SMTP_USER=
SMTP_PASS=
